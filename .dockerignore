# .dockerignore – exclude everything that shouldn't be sent to Docker build context
node_modules
npm-debug.log
yarn-debug.log
pnpm-debug.log

# Build artefacts
.next
out
build
-dist

# IDE & editor files
.vscode
*.code-workspace
*.DS_Store
Thumbs.db

# Environment / secrets
.env
*.env.*
secrets/
config/*.local.ts

# Test & coverage
coverage
*.test.*
*.spec.*

# Misc temporary files
*.log
*.tmp
*.temp
.eslintcache
.stylelintcache
