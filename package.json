{
  "name": "perception-mapper-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.8.0",
  "dependencies": {
    "next-themes": "^0.4.6",
    "turbo": "^2.9.14",
    "lucide-react": "^0.306.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:api": "npm --workspace api run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "concurrently": "^8.2.2"
  }
}
