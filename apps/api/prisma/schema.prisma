datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PlanTier {
  FREE
  PRO
  TEAM
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                     String       @id // Clerk User ID
  email                  String       @unique
  name                   String?
  stripeCustomerId       String?      @unique
  stripeSubscriptionId   String?      @unique
  tier                   PlanTier     @default(FREE)
  role                   UserRole     @default(USER)
  status                 String       @default("ACTIVE") // ACTIVE | BLOCKED
  plan                   String       @default("FREE")   // FREE | PRO | TEAM
  analysesLimit          Int          @default(50)
  analysesUsed           Int          @default(0)
  lastLogin              DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  analyses               Analysis[]
  apiKeys                ApiKey[]
  customRules            CustomRule[]
}

model Analysis {
  id               String   @id @default(uuid())
  userId           String
  inputText        String   @db.Text
  detectedLanguage String
  sentimentScore   Int
  biasIndex        Int
  tones            Json     // List of matched tone profiles
  biases           Json     // List of flagged bias details
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique // Hashed key representation
  userId    String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomRule {
  id          String   @id @default(uuid())
  userId      String
  pattern     String   // Regex pattern for target bias
  type        String   // Category of custom bias
  description String
  rephrase    String   // Recommended objective alternative
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  activity    String   // "LOGIN", "ANALYSIS", "VOICE_INPUT", "IMAGE_UPLOAD"
  details     String?
  status      String   // "SUCCESS", "FAILED"
  latencyMs   Int      @default(0)
  tokensCount Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Policy {
  id                 String   @id @default("global-policy")
  textEnabled        Boolean  @default(true)
  voiceEnabled       Boolean  @default(true)
  imageEnabled       Boolean  @default(true)
  limitFree          Int      @default(50)
  limitPro           Int      @default(500)
  limitTeam          Int      @default(5000)
  rateFree           Int      @default(10)
  ratePro            Int      @default(60)
  rateTeam           Int      @default(300)
  experimentalToggle Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}
