# PostgreSQL Connection String (Compatible with Supabase / AWS RDS)
DATABASE_URL="postgresql://postgres:password@localhost:5432/perception_mapper?schema=public"

# Clerk Verification Credentials
# Ensure this matches the sk_test key utilized on your web client dashboard
CLERK_SECRET_KEY=sk_test_placeholder_key

# Optional: Custom Clerk JSON Web Key Sets (JWKS) signature validation URL
CLERK_JWKS_URI=https://api.clerk.com/v1/jwks

# Core gateway execution port
PORT=3001
