# General ignore rules for Perception_Mapper_AI

# OS / editor artefacts
.DS_Store
Thumbs.db
*.sublime-*
*.code-workspace

# VS Code settings (keep only shared settings if needed)
.vscode/
!.vscode/settings.json

# Environment files and secrets (never commit)
.env
*.env.*
secrets/
config/*.local.ts

# Node / npm
node_modules/
npm-debug.log
yarn-debug.log
pnpm-debug.log
# If you prefer to lock versions, keep the lock file; otherwise you can ignore it
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Build artefacts (Next.js, other frameworks)
.next/
out/
build/
dist/
dist/**
**/dist/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# TypeScript build info
*.tsbuildinfo

# TurboRepo cache
.turbo/
# turbo.lock.json  # uncomment if you want to ignore the lock file

# Test & coverage
coverage/
*.test.*
*.spec.*
jest.config.cjs

# Docker / container cache
docker-compose.override.yml

# Misc temporary files
*.log
*.tmp
*.temp
.eslintcache
.stylelintcache